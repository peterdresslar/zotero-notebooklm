{
  "manifest_version": 3,
  "name": "Zotero to Gemini Notebook",
  "version": "0.3.1",
  "description": "Import staged Zotero sources into Gemini Notebook",
  "permissions": ["activeTab"],
  "host_permissions": [
    "http://127.0.0.1:23119/*",
    "https://notebooklm.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["upload-transfer.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["injector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
